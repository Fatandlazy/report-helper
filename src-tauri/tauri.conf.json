{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Report Helper",
  "version": "0.1.2",
  "identifier": "com.thuantd.report-helper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Report Helper",
        "width": 1200,
        "height": 720,
        "minWidth": 900,
        "minHeight": 540,
        "decorations": false,
        "shadow": true,
        "dragDropEnabled": false,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
